# Copy to .env and adjust. Compose injects these for the api service automatically;
# this file is for running the app or tests directly on the host.
DATABASE_URL=postgresql+psycopg://ticketflow:ticketflow@localhost:5432/ticketflow
REDIS_URL=redis://localhost:6379/0
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
SEAT_HOLD_SECONDS=120
MAX_SEATS_PER_BOOKING=8
RATE_LIMIT_PER_MINUTE=120
ENVIRONMENT=development
