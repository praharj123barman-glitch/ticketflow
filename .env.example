# Copy to .env and adjust. Compose injects these for the api service automatically;
# this file is for running the app or tests directly on the host.
DATABASE_URL=postgresql+psycopg://ticketflow:ticketflow@localhost:5432/ticketflow
REDIS_URL=redis://localhost:6379/0
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
SEAT_HOLD_SECONDS=120
MAX_SEATS_PER_BOOKING=8
RATE_LIMIT_PER_MINUTE=120
ENVIRONMENT=development

# Public origin (no trailing slash) — used for OG/share links, the sitemap, and
# the Stripe success/cancel return URLs. Set to your domain in production.
PUBLIC_BASE_URL=http://localhost:5173

# DB connection pool, PER gunicorn worker. N workers => up to
# N*(POOL_SIZE+MAX_OVERFLOW) connections; keep under Postgres max_connections.
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=10

# --- Payments (Stripe, TEST mode) ---
# Leave blank to run the offline "fake" flow (the live demo is bookable without
# keys via the dev-confirm path). Set TEST-mode keys to enable real Stripe
# Checkout: get them at https://dashboard.stripe.com/test/apikeys and create a
# webhook to {PUBLIC_BASE_URL}/api/webhooks/stripe for `checkout.session.completed`.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=
CURRENCY=inr

# --- Email (transactional) ---
# Leave SMTP_HOST blank to use the dev outbox (logged, never sent). Set these to
# send real confirmation emails (e.g. a transactional provider's SMTP creds).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=TicketFlow <no-reply@ticketflow.dev>
